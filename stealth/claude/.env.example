# =============================================================================
# Psi · .env.example
# -----------------------------------------------------------------------------
# 12-Factor III — Config:  Todo parâmetro de ambiente vive AQUI.
# Copie para `.env` (nunca commite) e preencha os valores.
#
#   cp .env.example .env
#
# Valida ao subir a aplicação em `src/lib/config.ts` (fail-fast).
# =============================================================================

# -----------------------------------------------------------------------------
# App
# -----------------------------------------------------------------------------
NODE_ENV=development                 # development | production | test
PUBLIC_APP_NAME=Psi
PUBLIC_APP_URL=http://localhost:5173 # usado em OAuth redirects e TTS callbacks
PUBLIC_APP_TIMEZONE=America/Sao_Paulo
LOG_LEVEL=info                       # trace | debug | info | warn | error (12-factor XI)
PORT=5173                            # 12-factor VII (port binding)

# -----------------------------------------------------------------------------
# Supabase  (backing service — 12-factor IV)
# -----------------------------------------------------------------------------
# "PUBLIC_" = exposto ao browser (SvelteKit convenção)
PUBLIC_SUPABASE_URL=https://xxxxxxxx.supabase.co
PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJI...
# ATENÇÃO: service role key NUNCA deve ter prefixo PUBLIC_ e NUNCA vai ao browser.
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJI...
SUPABASE_JWT_SECRET=super-secret-jwt

# Chave usada pelo pgcrypto (armazenada no Supabase Vault em prod)
SUPABASE_ENCRYPTION_KEY=change-me-32-byte-min-in-production

# -----------------------------------------------------------------------------
# Redis — Upstash  (backing service — 12-factor IV)
# -----------------------------------------------------------------------------
UPSTASH_REDIS_REST_URL=https://us1-xxxxx.upstash.io
UPSTASH_REDIS_REST_TOKEN=AXxxx...

# -----------------------------------------------------------------------------
# Google OAuth + Calendar  (Paciente = interface 2)
# -----------------------------------------------------------------------------
GOOGLE_CLIENT_ID=xxxxxxxx.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-xxxx
GOOGLE_REDIRECT_URI=http://localhost:5173/auth/callback
GOOGLE_CALENDAR_SCOPES=https://www.googleapis.com/auth/calendar.events https://www.googleapis.com/auth/calendar.readonly

# -----------------------------------------------------------------------------
# LLM  (OpenAI-compatible — trocável por qualquer provider)
# -----------------------------------------------------------------------------
LLM_BASE_URL=https://api.openai.com/v1
LLM_API_KEY=sk-xxxx
LLM_MODEL=gpt-4o-mini
LLM_PROVIDER=openai                  # usado nos logs de ai_usage_logs

# -----------------------------------------------------------------------------
# ElevenLabs (TTS)
# -----------------------------------------------------------------------------
ELEVENLABS_API_KEY=xxxxxxxx
ELEVENLABS_VOICE_ID=21m00Tcm4TlvDq8ikWAM     # "Rachel" (default pt-BR-compat)
ELEVENLABS_MODEL=eleven_turbo_v2_5
ELEVENLABS_OUTPUT_FORMAT=mp3_44100_128

# -----------------------------------------------------------------------------
# Admin bootstrap
# -----------------------------------------------------------------------------
# Emails (separados por vírgula) que serão promovidos a admin no primeiro login.
# Ative via migration seed ou comando admin (12-factor XII).
ADMIN_EMAILS=antonio.quental@gmail.com

# -----------------------------------------------------------------------------
# Observabilidade  (12-factor XI — logs para stdout)
# -----------------------------------------------------------------------------
SENTRY_DSN=                          # opcional
OTEL_EXPORTER_OTLP_ENDPOINT=         # opcional (traces)

# -----------------------------------------------------------------------------
# Rate limiting (Redis-backed)
# -----------------------------------------------------------------------------
RATE_LIMIT_AI_CHAT_PER_MIN=20
RATE_LIMIT_TTS_CHARS_PER_HOUR=20000

# -----------------------------------------------------------------------------
# Feature flags
# -----------------------------------------------------------------------------
PUBLIC_FEATURE_VOICE_CHAT=true
PUBLIC_FEATURE_TELEGRAM_OMNICHANNEL=false
